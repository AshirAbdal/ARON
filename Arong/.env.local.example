# SMTP configuration for order confirmation emails
SMTP_HOST=mail.aronbd.net
SMTP_PORT=465
SMTP_USER=noreply@aronbd.net
SMTP_PASS=your_smtp_password_here
SMTP_FROM=noreply@aronbd.net
SMTP_FROM_NAME=ARON
BRAND_NAME=ARON

# Admin notifications (every new order)
ADMIN_NOTIFY_EMAIL=arononlineshopinfo@gmail.com

# Telegram order notifications
# See Arong/lib/telegram.ts for setup instructions
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Cloudflare Turnstile captcha
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

